{
    "preset": "laravel",
    "rules": {
        "blank_line_before_statement": {
            "statements": [
                "break",
                "continue",
                "declare",
                "return",
                "throw",
                "try"
            ]
        },
        "concat_space": {
            "spacing": "none"
        },
        "declare_strict_types": true,
        "not_operator_with_space": false,
        "ordered_imports": {
            "sort_algorithm": "alpha"
        }
    }
}
